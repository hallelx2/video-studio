# ─── TTS — Microsoft Edge Read Aloud (default, free, no API key required) ───
# Pick from https://learn.microsoft.com/en-us/azure/ai-services/speech-service/language-support
# Recommended SaaS narrator voices:
#   en-US-AndrewNeural     (warm male, conversational)  ← default
#   en-US-AriaNeural       (clear female, neutral)
#   en-US-ChristopherNeural (deep male, authoritative)
#   en-US-JennyNeural      (warm female, friendly)
#   en-GB-RyanNeural       (British male, calm)
#   en-GB-SoniaNeural      (British female, professional)
TTS_VOICE=en-US-AndrewNeural

# ─── Paths ───
# Absolute path to the Remotion studio workspace (set automatically by Tauri at runtime;
# only override for CLI-only runs)
VIDEO_STUDIO_STUDIO_PATH=

# Absolute path to the organisation-projects folder (where product repos live)
ORG_PROJECTS_PATH=C:\Users\HomePC\Documents\organisation-projects

# Absolute path to the obsidian outreach folder (voice references live here)
OBSIDIAN_OUTREACH_PATH=C:\Users\HomePC\Documents\obsidian\outreach
