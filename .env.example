# Optional fallback env vars for the agent.
# Normal usage: configure these via the in-app Settings (stored at <userData>/config.json).
# These env vars are only read if the user hasn't completed onboarding yet, or if
# you're running the agent CLI standalone (without Electron).

# ─── TTS — Kokoro voices (built into HyperFrames, free, offline) ───
# Run `npx hyperframes tts --list` to see all available voices.
# Common picks:
#   af_nova    (US female, clear, modern)        ← default
#   af_bella   (US female, warm, conversational)
#   af_sarah   (US female, professional)
#   am_adam    (US male, mature, authoritative)
#   am_michael (US male, friendly, founder-like)
#   bf_emma    (UK female, refined)
#   bm_george  (UK male, calm)
TTS_VOICE=af_nova

# Absolute path to the folder that holds your project repos
ORG_PROJECTS_PATH=C:\Users\HomePC\Documents\organisation-projects

# Optional: override where HyperFrames workspaces are created.
# Defaults to <userData>/workspace (e.g. %APPDATA%/video-studio/workspace on Windows).
# WORKSPACE_PATH=
