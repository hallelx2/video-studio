# Use a flat (hoisted) node_modules tree so packaging tools like
# electron-builder can pack `agent/node_modules/**` into an asar without
# losing transitive deps. With pnpm's default isolated linker, real files
# live under `node_modules/.pnpm/<pkg>/` and `agent/node_modules/<pkg>` is
# only a symlink; electron-builder follows the symlink for the entry but
# the target's own `node_modules/.pnpm/` ancestry is outside the files
# glob, so transitive imports fail at runtime with ERR_MODULE_NOT_FOUND.
node-linker=hoisted
