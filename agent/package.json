{
  "name": "@video-studio/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "embed-prompt": "node scripts/embed-prompt.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "pnpm embed-prompt && pnpm typecheck && node esbuild.config.mjs",
    "dev": "pnpm embed-prompt && tsc -p tsconfig.json -w",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.107",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  }
}
