{
  "name": "video-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Desktop agent-driven video studio for SaaS product launches",
  "scripts": {
    "dev": "pnpm tauri dev",
    "build": "pnpm sidecar:windows && pnpm tauri build",
    "bundle": "pnpm sidecar:windows && pnpm tauri build",
    "bundle:macos": "pnpm sidecar:macos && pnpm tauri build",
    "bundle:linux": "pnpm sidecar:linux && pnpm tauri build",
    "tauri": "tauri",
    "frontend:dev": "vite",
    "frontend:build": "tsc -b && vite build",
    "agent:build": "pnpm --filter @video-studio/agent build",
    "agent:dev": "pnpm --filter @video-studio/agent dev",
    "sidecar:windows": "pnpm --filter @video-studio/agent compile:windows",
    "sidecar:macos": "pnpm --filter @video-studio/agent compile:macos-arm && pnpm --filter @video-studio/agent compile:macos-x64",
    "sidecar:linux": "pnpm --filter @video-studio/agent compile:linux",
    "studio:dev": "pnpm --filter @video-studio/studio dev",
    "studio:render": "pnpm --filter @video-studio/studio render"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.0",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.8.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
