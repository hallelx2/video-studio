{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Video Studio",
  "version": "0.1.0",
  "identifier": "dev.hallelx2.video-studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm frontend:dev",
    "beforeBuildCommand": "pnpm frontend:build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Video Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Agent-driven video studio for SaaS launches",
    "longDescription": "Video Studio turns your product README into launch-ready videos across LinkedIn, X, YouTube and hero formats using your local Claude subscription, edge-tts voices, and Remotion rendering.",
    "externalBin": ["binaries/agent"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
